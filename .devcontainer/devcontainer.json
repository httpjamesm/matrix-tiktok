{
  "name": "matrix-tiktok",
  "dockerComposeFile": "docker-compose.yml",
  "service": "app",
  "workspaceFolder": "/workspaces/matrix-tiktok",
  "containerEnv": {
    "DATABASE_URL": "postgres://bridge:tiktok@db:5432/matrix?sslmode=disable",
    "PGHOST": "db",
    "PGPORT": "5432",
    "PGUSER": "bridge",
    "PGPASSWORD": "tiktok",
    "PGDATABASE": "matrix"
  },
  "forwardPorts": ["db:5432"],
  "customizations": {
    "vscode": {
      "extensions": ["golang.Go"],
      "settings": {
        "go.toolsManagement.autoUpdate": true,
        "go.useLanguageServer": true,
        "go.lintTool": "staticcheck"
      }
    }
  },
  "postCreateCommand": "go version && bbctl --help >/dev/null",
  "remoteUser": "vscode"
}
